# =============================================
# GOOGLE GEMINI API KEY CONFIGURATION
# =============================================
# Lấy key tại: https://aistudio.google.com/app/apikey
# =============================================

GEMINI_API_KEY=your_gemini_api_key_here

# =============================================
# OPENAI GPT-IMAGE API KEY CONFIGURATION
# =============================================
# Lấy key tại: https://platform.openai.com/api-keys
# Hỗ trợ models: gpt-image-2 (default), gpt-image-1, gpt-image-1-mini, gpt-image-1.5
# =============================================

OPENAI_API_KEY=your_openai_api_key_here

# =============================================
# DEFAULT MODEL
# =============================================
# Google: gemini-3-pro-image-preview | imagen-4.0-generate-001 | imagen-4.0-fast-generate-001
# OpenAI: gpt-image-2 | gpt-image-1 | gpt-image-1-mini | gpt-image-1.5
# =============================================

IMAGE_MODEL=gemini-3-pro-image-preview
