# =============================================
# GOOGLE GEMINI API KEY CONFIGURATION
# =============================================
# Cách 1 (Ưu tiên): Điền key vào đây
# Cách 2 (Thay thế): export GEMINI_API_KEY=your_key_here trong ~/.zshrc
#
# Lấy key tại: https://aistudio.google.com/app/apikey
# =============================================

GEMINI_API_KEY=your_gemini_api_key_here

# Chọn model tạo ảnh:
# - imagen-3.0-generate-002         : Imagen 3 - chất lượng cao nhất (recommended)
# - gemini-2.0-flash-exp            : Gemini Flash - nhanh, đa năng
IMAGE_MODEL=imagen-3.0-generate-002
